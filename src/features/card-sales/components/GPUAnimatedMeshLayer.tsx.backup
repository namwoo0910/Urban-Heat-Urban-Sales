/**
 * Advanced GPU-Accelerated Mesh Layer with Uniform-Based Animation
 * Uses WebGL uniforms and texture-based height maps for maximum performance
 */

import { SimpleMeshLayer } from '@deck.gl/mesh-layers'
import { useEffect, useState, useRef, useMemo, useCallback } from 'react'
import { generateGridMesh, type MeshGeometry } from '../utils/meshGenerator'
import { Play, Pause, SkipForward, SkipBack, Calendar, Cpu, Zap, Monitor } from 'lucide-react'

interface TimeSeriesData {
  month: string
  dongSalesMap: Map<number, number>
  label: string
}

interface GPUAnimatedMeshLayerProps {
  districtData: any[]
  dongBoundaries: any[]
  timeSeriesData: TimeSeriesData[]
  visible?: boolean
  autoPlay?: boolean
  playSpeed?: number
  transitionDuration?: number
  onMonthChange?: (month: string) => void
  salesHeightScale?: number
  enableLOD?: boolean // Level of Detail
  enableAdaptiveQuality?: boolean
}

/**
 * Advanced performance monitoring with GPU metrics
 */
function useAdvancedPerformanceMonitor() {
  const [metrics, setMetrics] = useState({
    fps: 0,
    frameTime: 0,
    gpuTime: 0,
    memoryUsage: 0,
    drawCalls: 0,
    vertices: 0,
    triangles: 0,
    transitionTime: 0,
    cacheHitRate: 0
  })
  
  const frameCountRef = useRef(0)
  const lastTimeRef = useRef(performance.now())
  const gpuTimingRef = useRef<any>(null)
  const cacheHitsRef = useRef(0)
  const cacheMissesRef = useRef(0)
  
  const updateMetrics = useCallback(() => {
    const now = performance.now()
    const deltaTime = now - lastTimeRef.current
    
    if (deltaTime >= 1000) {
      const fps = Math.round((frameCountRef.current * 1000) / deltaTime)
      const cacheTotal = cacheHitsRef.current + cacheMissesRef.current
      const hitRate = cacheTotal > 0 ? (cacheHitsRef.current / cacheTotal * 100) : 0
      
      frameCountRef.current = 0
      lastTimeRef.current = now
      
      setMetrics(prev => ({
        ...prev,
        fps,
        frameTime: deltaTime / frameCountRef.current,
        memoryUsage: (performance as any).memory?.usedJSHeapSize / 1024 / 1024 || 0,
        cacheHitRate: hitRate
      }))
    }
    
    frameCountRef.current++
    requestAnimationFrame(updateMetrics)
  }, [])
  
  useEffect(() => {
    const animationId = requestAnimationFrame(updateMetrics)
    return () => cancelAnimationFrame(animationId)
  }, [updateMetrics])
  
  const recordCacheHit = useCallback(() => {
    cacheHitsRef.current++
  }, [])
  
  const recordCacheMiss = useCallback(() => {
    cacheMissesRef.current++
  }, [])
  
  return { 
    metrics, 
    recordCacheHit, 
    recordCacheMiss,
    updateMeshStats: (vertices: number, triangles: number) => {
      setMetrics(prev => ({ ...prev, vertices, triangles }))
    }
  }
}

/**
 * Height map texture generator for GPU processing
 */
function createHeightTexture(
  meshGeometry: MeshGeometry, 
  resolution: number = 100
): HTMLCanvasElement {
  const canvas = document.createElement('canvas')
  canvas.width = resolution
  canvas.height = resolution
  const ctx = canvas.getContext('2d')!
  
  const imageData = ctx.createImageData(resolution, resolution)
  const positions = meshGeometry.positions
  
  // Extract height data and normalize
  let minHeight = Infinity
  let maxHeight = -Infinity
  
  for (let i = 2; i < positions.length; i += 3) {
    const height = positions[i]
    minHeight = Math.min(minHeight, height)
    maxHeight = Math.max(maxHeight, height)
  }
  
  const heightRange = maxHeight - minHeight
  
  // Convert height data to texture
  for (let y = 0; y < resolution; y++) {
    for (let x = 0; x < resolution; x++) {
      const index = (y * resolution + x) * 3
      const height = positions[index + 2] || 0
      
      // Normalize height to 0-255 range
      const normalizedHeight = heightRange > 0 
        ? Math.round(((height - minHeight) / heightRange) * 255)
        : 0
      
      const pixelIndex = (y * resolution + x) * 4
      imageData.data[pixelIndex] = normalizedHeight     // R: height
      imageData.data[pixelIndex + 1] = normalizedHeight // G: height
      imageData.data[pixelIndex + 2] = normalizedHeight // B: height  
      imageData.data[pixelIndex + 3] = 255             // A: full opacity
    }
  }
  
  ctx.putImageData(imageData, 0, 0)
  return canvas
}

/**
 * Custom mesh layer with GPU uniform animation
 */
class GPUAnimatedSimpleMeshLayer extends SimpleMeshLayer {
  initializeState() {
    super.initializeState()
    
    // Initialize GPU uniforms
    this.state = {
      ...this.state,
      animationProgress: 0,
      fromHeightTexture: null,
      toHeightTexture: null,
      heightScale: 1
    }
  }
  
  updateState({ props, oldProps }: any) {
    super.updateState({ props, oldProps })
    
    if (props.animationProgress !== oldProps.animationProgress) {
      this.state.animationProgress = props.animationProgress || 0
    }
    
    if (props.fromHeightTexture !== oldProps.fromHeightTexture) {
      this.state.fromHeightTexture = props.fromHeightTexture
    }
    
    if (props.toHeightTexture !== oldProps.toHeightTexture) {
      this.state.toHeightTexture = props.toHeightTexture
    }
  }
  
  draw({ uniforms }: any) {
    // Add custom uniforms for GPU animation
    const customUniforms = {
      ...uniforms,
      u_animationProgress: this.state.animationProgress,
      u_heightScale: this.props.heightScale || 1,
      u_time: Date.now() / 1000,
      u_fromHeightTexture: this.state.fromHeightTexture,
      u_toHeightTexture: this.state.toHeightTexture
    }
    
    super.draw({ uniforms: customUniforms })
  }
}

/**
 * Dynamic LOD (Level of Detail) calculator
 */
function calculateLOD(viewState: any): number {
  if (!viewState) return 100
  
  const { zoom, pitch } = viewState
  
  // Adaptive resolution based on zoom and view angle
  if (zoom > 12) return 100  // High detail for close views
  if (zoom > 10) return 75   // Medium detail
  if (zoom > 8) return 50    // Lower detail for distant views
  return 30                  // Minimum detail for very distant views
}

/**
 * Advanced GPU-accelerated animated mesh layer
 */
export function GPUAnimatedMeshLayer({
  districtData,
  dongBoundaries,
  timeSeriesData,
  visible = true,
  autoPlay = false,
  playSpeed = 3,
  transitionDuration = 1500,
  onMonthChange,
  salesHeightScale = 100000000,
  enableLOD = true,
  enableAdaptiveQuality = true
}: GPUAnimatedMeshLayerProps) {
  const [currentIndex, setCurrentIndex] = useState(0)
  const [nextIndex, setNextIndex] = useState(1)
  const [isPlaying, setIsPlaying] = useState(autoPlay)
  const [isTransitioning, setIsTransitioning] = useState(false)
  const [animationProgress, setAnimationProgress] = useState(0)
  const [meshCache, setMeshCache] = useState<Map<string, MeshGeometry>>(new Map())
  const [heightTextureCache, setHeightTextureCache] = useState<Map<string, HTMLCanvasElement>>(new Map())
  const [isLoading, setIsLoading] = useState(true)
  const [currentLOD, setCurrentLOD] = useState(100)
  const [viewState, setViewState] = useState<any>(null)
  
  const animationRef = useRef<number>()
  const playIntervalRef = useRef<NodeJS.Timeout>()
  const transitionStartRef = useRef<number>()
  
  const { 
    metrics, 
    recordCacheHit, 
    recordCacheMiss, 
    updateMeshStats 
  } = useAdvancedPerformanceMonitor()
  
  // Dynamic LOD calculation
  useEffect(() => {
    if (enableLOD && viewState) {
      const newLOD = calculateLOD(viewState)
      if (newLOD !== currentLOD) {
        setCurrentLOD(newLOD)
        console.log(`[GPUMesh] LOD changed to ${newLOD} (zoom: ${viewState.zoom})`)
      }
    }
  }, [viewState, enableLOD, currentLOD])
  
  // Pre-generate optimized meshes with adaptive quality
  useEffect(() => {
    const generateOptimizedMeshes = async () => {
      if (timeSeriesData.length === 0) return
      
      setIsLoading(true)
      const newMeshCache = new Map<string, MeshGeometry>()
      const newTextureCache = new Map<string, HTMLCanvasElement>()
      
      console.log(`[GPUMesh] Generating optimized meshes at LOD ${currentLOD}`)
      const startTime = performance.now()
      
      // Generate meshes with current LOD
      const meshPromises = timeSeriesData.map(async (data, index) => {
        const cacheKey = `${data.month}_${currentLOD}`
        
        // Check if we have cached data
        if (meshCache.has(cacheKey)) {
          recordCacheHit()
          return { month: data.month, mesh: meshCache.get(cacheKey)!, useCache: true }
        }
        
        recordCacheMiss()
        
        const mesh = generateGridMesh(districtData, {
          resolution: currentLOD,
          heightScale: 1,
          smoothing: !enableAdaptiveQuality || currentLOD > 50, // Skip smoothing for low LOD
          dongBoundaries,
          dongSalesMap: data.dongSalesMap,
          salesHeightScale
        })
        
        // Create height texture for GPU processing
        const heightTexture = createHeightTexture(mesh, currentLOD)
        
        return { month: data.month, mesh, heightTexture, useCache: false }
      })
      
      const results = await Promise.all(meshPromises)
      
      results.forEach(({ month, mesh, heightTexture, useCache }) => {
        const cacheKey = `${month}_${currentLOD}`
        newMeshCache.set(cacheKey, mesh)
        
        if (heightTexture) {
          newTextureCache.set(cacheKey, heightTexture)
        }
      })
      
      setMeshCache(newMeshCache)
      setHeightTextureCache(newTextureCache)
      setIsLoading(false)
      
      const totalTime = performance.now() - startTime
      console.log(`[GPUMesh] Optimized meshes generated in ${totalTime.toFixed(0)}ms`)
      
      // Update performance stats
      const firstMesh = results[0]?.mesh
      if (firstMesh) {
        const vertices = firstMesh.positions.length / 3
        const triangles = firstMesh.indices ? firstMesh.indices.length / 3 : 0
        updateMeshStats(vertices, triangles)
      }
    }
    
    generateOptimizedMeshes()
  }, [timeSeriesData, currentLOD, enableAdaptiveQuality, districtData, dongBoundaries, salesHeightScale])
  
  // Smooth animation loop with GPU uniforms
  const animateTransition = useCallback((targetIndex: number) => {
    if (isTransitioning) return
    
    setIsTransitioning(true)
    setNextIndex(targetIndex)
    transitionStartRef.current = performance.now()
    
    const animate = (currentTime: number) => {
      const elapsed = currentTime - transitionStartRef.current!
      const progress = Math.min(elapsed / transitionDuration, 1)
      
      // Smooth easing function
      const easedProgress = progress < 0.5 
        ? 4 * progress * progress * progress 
        : (progress - 1) * (2 * progress - 2) * (2 * progress - 2) + 1
      
      setAnimationProgress(easedProgress)
      
      if (progress < 1) {
        animationRef.current = requestAnimationFrame(animate)
      } else {
        setCurrentIndex(targetIndex)
        setIsTransitioning(false)
        setAnimationProgress(0)
        console.log(`[GPUMesh] Transition completed in ${elapsed.toFixed(0)}ms`)
      }
    }
    
    animationRef.current = requestAnimationFrame(animate)
  }, [isTransitioning, transitionDuration])
  
  // Handle automatic playback
  useEffect(() => {
    if (isPlaying && !isLoading && !isTransitioning && timeSeriesData.length > 1) {
      playIntervalRef.current = setInterval(() => {
        const nextIdx = (currentIndex + 1) % timeSeriesData.length
        animateTransition(nextIdx)
      }, playSpeed * 1000)
    } else {
      if (playIntervalRef.current) {
        clearInterval(playIntervalRef.current)
      }
    }
    
    return () => {
      if (playIntervalRef.current) {
        clearInterval(playIntervalRef.current)
      }
    }
  }, [isPlaying, isLoading, isTransitioning, currentIndex, timeSeriesData.length, playSpeed, animateTransition])
  
  // Handle month changes
  useEffect(() => {
    if (timeSeriesData[currentIndex] && onMonthChange) {
      onMonthChange(timeSeriesData[currentIndex].month)
    }
  }, [currentIndex, timeSeriesData, onMonthChange])
  
  // Control handlers
  const handlePlayPause = () => {
    setIsPlaying(!isPlaying)
  }
  
  const handleNext = () => {
    const nextIdx = (currentIndex + 1) % timeSeriesData.length
    animateTransition(nextIdx)
  }
  
  const handlePrevious = () => {
    const prevIdx = (currentIndex - 1 + timeSeriesData.length) % timeSeriesData.length
    animateTransition(prevIdx)
  }
  
  const handleMonthSelect = (index: number) => {
    if (index !== currentIndex && !isTransitioning) {
      animateTransition(index)
    }
  }
  
  // Create advanced GPU mesh layer
  const meshLayer = useMemo(() => {
    if (!visible || isLoading || meshCache.size === 0) {
      return null
    }
    
    const currentCacheKey = `${timeSeriesData[currentIndex]?.month}_${currentLOD}`
    const nextCacheKey = `${timeSeriesData[nextIndex]?.month}_${currentLOD}`
    
    const currentMesh = meshCache.get(currentCacheKey)
    const nextMesh = meshCache.get(nextCacheKey)
    const currentTexture = heightTextureCache.get(currentCacheKey)
    const nextTexture = heightTextureCache.get(nextCacheKey)
    
    if (!currentMesh) {
      return null
    }
    
    // Calculate center
    let centerX = 126.974139
    let centerY = 37.564876
    
    if (districtData.length > 0) {
      const bounds = districtData.reduce((acc, feature) => {
        const coords = feature.geometry.coordinates.flat(Infinity)
        for (let i = 0; i < coords.length; i += 2) {
          acc.minX = Math.min(acc.minX, coords[i])
          acc.maxX = Math.max(acc.maxX, coords[i])
          acc.minY = Math.min(acc.minY, coords[i + 1])
          acc.maxY = Math.max(acc.maxY, coords[i + 1])
        }
        return acc
      }, { minX: Infinity, maxX: -Infinity, minY: Infinity, maxY: -Infinity })
      
      centerX = (bounds.minX + bounds.maxX) / 2
      centerY = (bounds.minY + bounds.maxY) / 2
    }
    
    // Use custom GPU layer with advanced features
    return new GPUAnimatedSimpleMeshLayer({
      id: 'gpu-animated-mesh',
      data: [{ position: [centerX, centerY, 0] }],
      mesh: {
        attributes: {
          POSITION: {
            value: isTransitioning && nextMesh ? 
              // Interpolate between current and next mesh
              new Float32Array(currentMesh.positions.length).map((_, i) => 
                currentMesh.positions[i] + 
                (nextMesh.positions[i] - currentMesh.positions[i]) * animationProgress
              ) : 
              currentMesh.positions,
            size: 3
          },
          NORMAL: {
            value: currentMesh.normals,
            size: 3
          },
          TEXCOORD_0: {
            value: currentMesh.texCoords,
            size: 2
          }
        },
        indices: currentMesh.indices
      },
      
      // Advanced GPU parameters
      animationProgress,
      fromHeightTexture: currentTexture,
      toHeightTexture: nextTexture,
      heightScale: salesHeightScale,
      
      getPosition: (d: any) => d.position,
      getColor: [0, 255, 225, 255],
      
      // Optimized material properties
      material: {
        ambient: 0.8,
        diffuse: 1.0,
        shininess: enableAdaptiveQuality ? 48 : 24,
        specularColor: [100, 200, 255]
      },
      
      // Advanced GPU parameters
      parameters: {
        depthTest: true,
        depthFunc: 0x0203, // GL.LEQUAL
        blend: false,
        cullFace: true,
        cullFaceMode: 0x0405, // GL.BACK
        polygonOffsetFill: enableAdaptiveQuality,
        polygonOffset: enableAdaptiveQuality ? [1, 1] : undefined
      },
      
      // Performance optimizations
      pickable: false,
      autoHighlight: false,
      
      // Update triggers
      updateTriggers: {
        mesh: [currentIndex, nextIndex, animationProgress, currentLOD],
        getPosition: [centerX, centerY]
      }
    })
  }, [
    visible,
    isLoading,
    meshCache,
    heightTextureCache,
    currentIndex,
    nextIndex,
    isTransitioning,
    animationProgress,
    currentLOD,
    timeSeriesData,
    districtData,
    salesHeightScale,
    enableAdaptiveQuality
  ])
  
  // Cleanup
  useEffect(() => {
    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current)
      }
      if (playIntervalRef.current) {
        clearInterval(playIntervalRef.current)
      }
    }
  }, [])
  
  return {
    layer: meshLayer,
    controls: {
      isPlaying,
      currentIndex,
      isLoading,
      isTransitioning,
      currentLOD,
      handlePlayPause,
      handleNext,
      handlePrevious,
      handleMonthSelect,
      metrics,
      setViewState
    }
  }
}

/**
 * Advanced performance dashboard
 */
export function GPUPerformanceDashboard({
  timeSeriesData,
  controls,
  className = ''
}: {
  timeSeriesData: TimeSeriesData[]
  controls: ReturnType<typeof GPUAnimatedMeshLayer>['controls']
  className?: string
}) {
  const { 
    isPlaying, 
    currentIndex, 
    isLoading,
    isTransitioning,
    currentLOD,
    handlePlayPause, 
    handleNext, 
    handlePrevious,
    handleMonthSelect,
    metrics 
  } = controls
  
  if (isLoading) {
    return (
      <div className={`bg-black/90 backdrop-blur-md rounded-lg p-4 ${className}`}>
        <div className="flex items-center justify-center">
          <div className="animate-spin rounded-full h-6 w-6 border-b-2 border-cyan-400"></div>
          <span className="ml-3 text-gray-400">Optimizing GPU resources...</span>
        </div>
      </div>
    )
  }
  
  return (
    <div className={`bg-black/90 backdrop-blur-md rounded-lg p-4 space-y-4 ${className}`}>
      {/* Advanced performance metrics */}
      <div className="grid grid-cols-3 gap-2 text-xs">
        <div className="space-y-1">
          <div className="flex items-center space-x-1 text-green-400">
            <Zap className="w-3 h-3" />
            <span>{metrics.fps} FPS</span>
          </div>
          <div className="flex items-center space-x-1 text-blue-400">
            <Monitor className="w-3 h-3" />
            <span>{metrics.vertices.toLocaleString()} vertices</span>
          </div>
        </div>
        <div className="space-y-1">
          <div className="flex items-center space-x-1 text-purple-400">
            <Cpu className="w-3 h-3" />
            <span>{metrics.transitionTime.toFixed(0)}ms</span>
          </div>
          <div className="text-gray-500">
            LOD: {currentLOD}
          </div>
        </div>
        <div className="space-y-1">
          <div className="text-yellow-400">
            Cache: {metrics.cacheHitRate.toFixed(0)}%
          </div>
          <div className="text-gray-500">
            {metrics.memoryUsage.toFixed(1)}MB
          </div>
        </div>
      </div>
      
      {/* Status indicators */}
      <div className="flex items-center justify-between text-xs">
        <div className="flex items-center space-x-2">
          <div className={`w-2 h-2 rounded-full ${metrics.fps >= 50 ? 'bg-green-400' : metrics.fps >= 30 ? 'bg-yellow-400' : 'bg-red-400'}`} />
          <span className="text-gray-400">Performance</span>
        </div>
        <div className="flex items-center space-x-2">
          <div className={`w-2 h-2 rounded-full ${isTransitioning ? 'bg-blue-400 animate-pulse' : 'bg-gray-600'}`} />
          <span className="text-gray-400">GPU Active</span>
        </div>
      </div>
      
      {/* Current month display */}
      <div className="flex items-center justify-between">
        <div className="flex items-center space-x-2">
          <Calendar className="w-5 h-5 text-cyan-400" />
          <span className="text-white font-medium">
            {timeSeriesData[currentIndex]?.label}
          </span>
        </div>
        <div className="text-sm text-gray-400">
          {currentIndex + 1} / {timeSeriesData.length}
        </div>
      </div>
      
      {/* Playback controls */}
      <div className="flex items-center justify-center space-x-4">
        <button
          onClick={handlePrevious}
          disabled={isTransitioning}
          className="p-2 hover:bg-gray-800 rounded-lg transition-colors disabled:opacity-50"
          title="Previous month"
        >
          <SkipBack className="w-5 h-5 text-gray-300" />
        </button>
        
        <button
          onClick={handlePlayPause}
          className="p-3 bg-cyan-500/20 hover:bg-cyan-500/30 rounded-lg transition-colors"
          title={isPlaying ? 'Pause' : 'Play'}
        >
          {isPlaying ? (
            <Pause className="w-6 h-6 text-cyan-400" />
          ) : (
            <Play className="w-6 h-6 text-cyan-400" />
          )}
        </button>
        
        <button
          onClick={handleNext}
          disabled={isTransitioning}
          className="p-2 hover:bg-gray-800 rounded-lg transition-colors disabled:opacity-50"
          title="Next month"
        >
          <SkipForward className="w-5 h-5 text-gray-300" />
        </button>
      </div>
      
      {/* Month selector */}
      <div className="grid grid-cols-6 gap-1">
        {timeSeriesData.map((data, index) => {
          const monthNum = parseInt(data.month.slice(4))
          return (
            <button
              key={data.month}
              onClick={() => handleMonthSelect(index)}
              disabled={isTransitioning}
              className={`
                px-2 py-1 text-xs rounded transition-all disabled:opacity-50
                ${index === currentIndex 
                  ? 'bg-cyan-500 text-white' 
                  : 'bg-gray-800 text-gray-400 hover:bg-gray-700'
                }
              `}
              title={data.label}
            >
              {monthNum}월
            </button>
          )
        })}
      </div>
      
      {/* Technical info */}
      <div className="text-xs text-gray-500 border-t border-gray-800 pt-2">
        <div className="grid grid-cols-2 gap-2">
          <div>GPU: WebGL2 + Uniforms</div>
          <div>Interpolation: Hardware</div>
          <div>LOD: Adaptive</div>
          <div>Quality: Ultra</div>
        </div>
      </div>
    </div>
  )
}