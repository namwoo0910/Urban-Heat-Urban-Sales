/**
 * Async mesh generator using setTimeout for non-blocking behavior
 * Simpler alternative to Web Workers that doesn't require webpack config
 */

import { generateGridMesh, MeshGeneratorOptions, MeshGeometry } from './meshGenerator'

export interface AsyncMeshResult {
  geometry: MeshGeometry
  generationTime: number
}

export interface AsyncMeshProgress {
  progress: number
  message: string
}

/**
 * Generate mesh asynchronously using setTimeout chunks
 * This prevents UI blocking by breaking work into smaller pieces
 */
export async function generateMeshAsync(
  features: any[],
  options: MeshGeneratorOptions,
  onProgress?: (progress: AsyncMeshProgress) => void
): Promise<AsyncMeshResult> {
  const startTime = performance.now()
  
  // Report initial progress
  if (onProgress) {
    onProgress({
      progress: 0,
      message: 'Initializing mesh generation...'
    })
  }
  
  // Use setTimeout to break out of current call stack
  // This allows UI to update between chunks
  await new Promise(resolve => setTimeout(resolve, 0))
  
  if (onProgress) {
    onProgress({
      progress: 10,
      message: 'Processing district boundaries...'
    })
  }
  
  await new Promise(resolve => setTimeout(resolve, 0))
  
  if (onProgress) {
    onProgress({
      progress: 30,
      message: 'Calculating sales heights...'
    })
  }
  
  await new Promise(resolve => setTimeout(resolve, 0))
  
  if (onProgress) {
    onProgress({
      progress: 50,
      message: 'Generating mesh vertices...'
    })
  }
  
  // Generate the actual mesh
  // This is still synchronous but at least we've given UI time to update
  const geometry = generateGridMesh(features, options)
  
  if (onProgress) {
    onProgress({
      progress: 90,
      message: 'Finalizing mesh data...'
    })
  }
  
  await new Promise(resolve => setTimeout(resolve, 0))
  
  if (onProgress) {
    onProgress({
      progress: 100,
      message: 'Complete!'
    })
  }
  
  const generationTime = performance.now() - startTime
  
  return {
    geometry,
    generationTime
  }
}

/**
 * Wrapper class for managing async mesh generation
 */
export class AsyncMeshGenerator {
  private currentGeneration: Promise<AsyncMeshResult> | null = null
  private abortController: AbortController | null = null
  
  /**
   * Generate mesh with cancellation support
   */
  async generate(
    features: any[],
    options: MeshGeneratorOptions,
    onProgress?: (progress: AsyncMeshProgress) => void
  ): Promise<AsyncMeshResult> {
    // Cancel any existing generation
    this.cancel()
    
    // Create new abort controller
    this.abortController = new AbortController()
    const signal = this.abortController.signal
    
    // Start generation
    this.currentGeneration = this.generateWithSignal(features, options, onProgress, signal)
    
    try {
      return await this.currentGeneration
    } finally {
      this.currentGeneration = null
      this.abortController = null
    }
  }
  
  /**
   * Internal generation with abort signal
   */
  private async generateWithSignal(
    features: any[],
    options: MeshGeneratorOptions,
    onProgress: ((progress: AsyncMeshProgress) => void) | undefined,
    signal: AbortSignal
  ): Promise<AsyncMeshResult> {
    const startTime = performance.now()
    
    // Check for cancellation
    if (signal.aborted) {
      throw new Error('Generation cancelled')
    }
    
    // Report progress in chunks
    const progressSteps = [
      { progress: 0, message: 'Initializing...', delay: 0 },
      { progress: 20, message: 'Processing boundaries...', delay: 50 },
      { progress: 40, message: 'Calculating heights...', delay: 50 },
      { progress: 60, message: 'Generating vertices...', delay: 50 },
      { progress: 80, message: 'Building mesh...', delay: 50 }
    ]
    
    for (const step of progressSteps) {
      if (signal.aborted) {
        throw new Error('Generation cancelled')
      }
      
      if (onProgress) {
        onProgress({
          progress: step.progress,
          message: step.message
        })
      }
      
      await new Promise(resolve => setTimeout(resolve, step.delay))
    }
    
    // Generate mesh
    if (signal.aborted) {
      throw new Error('Generation cancelled')
    }
    
    const geometry = generateGridMesh(features, options)
    
    // Final progress
    if (onProgress) {
      onProgress({
        progress: 100,
        message: 'Complete!'
      })
    }
    
    const generationTime = performance.now() - startTime
    console.log(`[AsyncMeshGenerator] Mesh generated in ${generationTime.toFixed(0)}ms`)
    
    return {
      geometry,
      generationTime
    }
  }
  
  /**
   * Cancel current generation
   */
  cancel() {
    if (this.abortController) {
      this.abortController.abort()
      this.abortController = null
    }
    this.currentGeneration = null
  }
  
  /**
   * Check if generation is in progress
   */
  isGenerating(): boolean {
    return this.currentGeneration !== null
  }
}

// Singleton instance
let generatorInstance: AsyncMeshGenerator | null = null

/**
 * Get or create the async mesh generator instance
 */
export function getAsyncMeshGenerator(): AsyncMeshGenerator {
  if (!generatorInstance) {
    generatorInstance = new AsyncMeshGenerator()
  }
  return generatorInstance
}